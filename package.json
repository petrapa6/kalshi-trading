{
    "name": "predictions",
    "private": true,
    "packageManager": "pnpm@10.8.1",
    "scripts": {
        "dev": "sst dev",
        "dev:api": "uv run uvicorn api:app --host 0.0.0.0 --port 8000 --reload",
        "dev:dashboard": "cd dashboard && pnpm dev",
        "sst:deploy": "assume smooai.dev && eval \"$(direnv export zsh 2>/dev/null)\" && npx sst deploy",
        "sst:remove": "assume smooai.dev && eval \"$(direnv export zsh 2>/dev/null)\" && npx sst remove",
        "lint": "cd dashboard && pnpm lint",
        "lint:py": "uv run ruff check .",
        "fmt": "cd dashboard && pnpm fmt",
        "fmt:py": "uv run ruff format .",
        "typecheck": "cd dashboard && pnpm tsc --noEmit",
        "typecheck:py": "uv run ty check",
        "pre-commit-check": "bash scripts/pre-commit-check.sh",
        "cli": "pnpm --filter cli start"
    },
    "dependencies": {
        "sst": "^4.2.2"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "sharp"
        ]
    }
}
