{
    "name": "predictions",
    "private": true,
    "packageManager": "pnpm@10.8.1",
    "scripts": {
        "dev:api": "uv run uvicorn predictions.api:app --host 0.0.0.0 --port 8000 --reload",
        "dev:dashboard": "cd dashboard && pnpm dev",
        "lint": "cd dashboard && pnpm lint",
        "lint:py": "uv run ruff check .",
        "fmt": "cd dashboard && pnpm fmt",
        "fmt:py": "uv run ruff format .",
        "typecheck": "cd dashboard && pnpm tsc --noEmit",
        "typecheck:py": "uv run ty check",
        "pre-commit-check": "bash scripts/pre-commit-check.sh",
        "cli": "pnpm --filter cli start"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "sharp"
        ]
    }
}
