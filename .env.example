# ─────────────────────────────────────────────────────────────────────────────
# Kalshi Trading Scanner — environment variables
#
# Copy this file to .env and fill in the values. .env is gitignored and must
# never be committed. Production secrets live in SST (`npx sst secret set …`),
# not here.
# ─────────────────────────────────────────────────────────────────────────────

# --- Kalshi API (required to run the scanner) -------------------------------

# API key ID obtained from Kalshi (https://kalshi.com/sign-up/api)
KALSHI_API_KEY=

# RSA private key contents, PEM-formatted. Either set this inline (multi-line
# value with literal newlines) OR set KALSHI_PRIVATE_KEY_PATH instead.
KALSHI_PRIVATE_KEY=

# Path to the RSA private key file on disk. Only read when KALSHI_PRIVATE_KEY
# is not set. Useful for local development.
# KALSHI_PRIVATE_KEY_PATH=./secrets/kalshi.pem

# --- API + Dashboard auth ---------------------------------------------------

# Bearer token guarding every mutating API endpoint. Generate a long random
# string and share it between the backend and any client (dashboard, CLI).
API_TOKEN=

# Password for the dashboard login screen (hashed server-side before compare).
DASHBOARD_PASSWORD=

# --- Scanner tuning (can be overridden at runtime via the `config` table) ---

# If true, no real orders are placed — trades are logged with status "dry_run".
DRY_RUN=true

# Initial min YES ask in cents (overridden by DB config `min_yes_price`).
MIN_YES_PRICE=92

# % of available cash to bet per match (overridden by DB `bet_percent`).
BET_PERCENT=5.0

# Polling interval in seconds for the legacy scanner mode.
POLL_INTERVAL_SECONDS=10

# --- Database + backups -----------------------------------------------------

# SQLAlchemy URL. Default matches the Dockerfile runtime path in production.
DATABASE_URL=sqlite:///predictions.db

# S3 bucket for periodic DB snapshots (leave blank to disable backups).
DB_BACKUP_BUCKET=

# --- Dashboard (Next.js) ----------------------------------------------------

# Public API URL the dashboard fetches from. Set to your deployed API host.
NEXT_PUBLIC_API_URL=http://localhost:8000
