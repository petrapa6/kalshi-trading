# ─────────────────────────────────────────────────────────────────────────────
# Kalshi Trading Scanner — environment variables
#
# Copy this file to .env and fill in the values. .env is gitignored and must
# never be committed. This file is for local development only — the Home
# Assistant add-on takes its secrets from the add-on options UI instead.
# ─────────────────────────────────────────────────────────────────────────────

# --- Kalshi API (required to run the scanner) -------------------------------

# API key ID obtained from Kalshi (https://kalshi.com/sign-up/api)
KALSHI_API_KEY=

# RSA private key contents, PEM-formatted. Either set this inline (multi-line
# value with literal newlines) OR set KALSHI_PRIVATE_KEY_PATH instead.
KALSHI_PRIVATE_KEY=

# Path to the RSA private key file on disk. Only read when KALSHI_PRIVATE_KEY
# is not set. Useful for local development.
# KALSHI_PRIVATE_KEY_PATH=./secrets/kalshi.pem

# --- API + Dashboard auth ---------------------------------------------------

# Bearer token guarding every mutating API endpoint. Generate a long random
# string and share it between the backend and any client (dashboard, CLI).
API_TOKEN=

# Password for the dashboard login screen (hashed server-side before compare).
DASHBOARD_PASSWORD=

# --- Scanner tuning (can be overridden at runtime via the `config` table) ---

# Dry-run mode is a runtime DB config value (`dry_run`), toggled from the
# dashboard — not an env var. Missing or any value other than "false" means
# dry-run is ON (no real orders); only "false" enables live trading.

# Initial min YES ask in cents (overridden by DB config `min_yes_price`).
MIN_YES_PRICE=92

# % of available cash to bet per match (overridden by DB `bet_percent`).
BET_PERCENT=5.0

# Polling interval in seconds for the legacy scanner mode.
POLL_INTERVAL_SECONDS=10

# --- Database ---------------------------------------------------------------

# SQLAlchemy URL. The add-on overrides this to /data/predictions.db, which
# Home Assistant includes in its backups.
DATABASE_URL=sqlite:///predictions.db

# --- Dashboard (Next.js) ----------------------------------------------------

# API URL the dashboard's server-side proxy fetches from.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- API CORS ---------------------------------------------------------------

# Comma-separated extra origins allowed by the API's CORS middleware, in
# addition to the built-in localhost entries. Only needed if you serve the
# dashboard from a non-default local port.
CORS_ORIGINS=

# --- Soccer backtest -------------------------------------------------------

# API-Football v3 key from https://dashboard.api-football.com/register . Free plan = 100 requests/day, 30 req/min.
# The backtest cache uses batched fixture-detail calls (up to 20 fixtures per call).
API_FOOTBALL_KEY=

# Filesystem path for the soccer-match cache SQLite file. Defaults to the
# repo root in dev; the add-on overrides to /data/soccer-cache.db.
SOCCER_CACHE_DB_PATH=./soccer-cache.db

# --- Strategies engine -----------------------------------------------------

# STRATEGIES_PATH — path to the strategies YAML file used by the backtest
# engine and (Phase 3) the live scanner. Resolves relative to the process
# working directory. Default: "strategies.yaml" (repo root in dev,
# /app/strategies.yaml in the container).
# STRATEGIES_PATH=strategies.yaml
